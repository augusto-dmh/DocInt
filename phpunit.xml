<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Architecture">
            <directory>tests/Architecture</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="FILESYSTEM_DISK" value="s3"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PROCESSING_QUEUE_CONNECTION" value="sync"/>
        <env name="PROCESSING_OCR_PROVIDER" value="openai"/>
        <env name="PROCESSING_CLASSIFICATION_PROVIDER" value="openai"/>
        <env name="PROCESSING_RETRY_ATTEMPTS" value="3"/>
        <env name="PROCESSING_RETRY_BACKOFF" value="5,15,45"/>
        <env name="PROCESSING_SCAN_WAIT_DELAY_SECONDS" value="5"/>
        <env name="PROCESSING_PROVIDER_DEGRADED_REQUEUE_DELAY_SECONDS" value="30"/>
        <env name="PROCESSING_PROVIDER_CIRCUIT_FAILURE_THRESHOLD" value="3"/>
        <env name="PROCESSING_PROVIDER_CIRCUIT_COOLDOWN_SECONDS" value="60"/>
        <env name="PROCESSING_OPENAI_MODEL" value="gpt-4o-mini"/>
        <env name="PROCESSING_OPENAI_OCR_MODEL" value="gpt-4o-mini"/>
        <env name="PROCESSING_OPENAI_TIMEOUT" value="30"/>
        <env name="OPENAI_API_KEY" value="test-openai-key"/>
        <env name="OPENAI_BASE_URL" value="https://api.openai.com/v1"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
